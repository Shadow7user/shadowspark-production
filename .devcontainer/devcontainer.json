{
  "name": "ShadowSpark Codespace",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20",
  "postCreateCommand": "corepack enable && pnpm install",
  "forwardPorts": [3000],
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "Prisma.prisma",
        "bradlc.vscode-tailwindcss"
      ]
    }
  }
}
