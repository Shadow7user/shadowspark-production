{
  "name": "shadowspark-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:socket": "tsx server.ts",
    "build": "prisma generate && next build",
    "start": "prisma migrate deploy && NODE_ENV=production tsx server.ts",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:observability": "tsx src/lib/observability/observability.test.ts",
    "verify:core": "pnpm run typecheck && pnpm run test:observability",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "build:cloudflare": "opennextjs-cloudflare build",
    "dev:cloudflare": "opennextjs-cloudflare dev",
    "deploy:cloudflare": "opennextjs-cloudflare build && wrangler deploy",
    "preview:cloudflare": "opennextjs-cloudflare build && wrangler dev"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "6.10.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.38.0",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.10.0",
    "framer-motion": "^12.35.2",
    "ioredis": "^5.6.1",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-auth": "5.0.0-beta.30",
    "openai": "^6.21.0",
    "paystack-api": "^2.0.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.4.0",
    "twilio": "^5.12.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "6.10.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wrangler": "^4.70.0"
  },
  "pnpm": {
    "overrides": {
      "@auth/core": "0.41.0"
    }
  }
}