    "@mendable/firecrawl-js": "^4.18.2",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-table": "^8.21.3",
    "ai": "^6.0.158",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.73.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
