
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Base User model for application authentication
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String? // Required for Credentials provider
  role          Role      @default(USER)

  accounts Account[] // User-facing bank accounts
  payments Payment[] // All payments initiated by the user

  // NextAuth adapter models
  nextAuthAccounts NextAuthAccount[]
  sessions      Session[]
}

enum Role {
  USER    // Standard customer
  ADMIN   // Full system access
  SUPPORT // Can view user data, cannot initiate transactions
  FINANCE // Can view ledgers, trigger payouts, manage financial records
}

// NextAuth specific models

model NextAuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Represents a user-facing account (e.g., NGN Wallet, USD Wallet)
model Account {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name     String
  currency String
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  ledgerAccountId String        @unique
  ledgerAccount   LedgerAccount @relation(fields: [ledgerAccountId], references: [id])

  @@index([userId])
}

// Represents an internal ledger account in the double-entry system.
model LedgerAccount {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name    String
  type    LedgerAccountType
  account Account?
  entries LedgerEntry[]
}

// Represents a single financial event.
model Transaction {
  id             String        @id @default(cuid())
  createdAt      DateTime      @default(now())
  description    String
  idempotencyKey String        @unique
  entries        LedgerEntry[]
}

// A single entry (a credit or a debit) in a ledger account.
model LedgerEntry {
  id              String        @id @default(cuid())
  createdAt       DateTime      @default(now())
  transactionId   String
  transaction     Transaction   @relation(fields: [transactionId], references: [id])
  ledgerAccountId String
  ledgerAccount   LedgerAccount @relation(fields: [ledgerAccountId], references: [id])
  direction       EntryDirection
  amount          BigInt

  @@index([ledgerAccountId])
  @@index([transactionId])
}

// Tracks a payment attempt through a provider.
model Payment {
  id              String         @id @default(cuid())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  amount          BigInt         // Amount in smallest currency unit
  currency        String         // ISO 4217 currency code
  status          PaymentStatus  @default(PENDING)
  provider        PaymentProviderName
  providerPaymentId String       @unique // e.g., Paystack reference or Stripe Payment Intent ID

  userId          String
  user            User           @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([provider, providerPaymentId])
}

// Logs incoming webhook events for idempotency.
model WebhookEvent {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  provider        PaymentProviderName
  eventId         String    // The unique ID from the provider (e.g., event ID or signature)
  eventType       String
  payload         Json
  isProcessed     Boolean   @default(false)
  processingError String?

  @@unique([provider, eventId])
}

enum LedgerAccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum EntryDirection {
  CREDIT
  DEBIT
}

enum PaymentStatus {
  PENDING
  SUCCESSFUL
  FAILED
}

enum PaymentProviderName {
  PAYSTACK
  STRIPE
}
