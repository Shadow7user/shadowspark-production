generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Lead {
  id             String       @id @default(cuid())
  phoneNumber    String?      @unique
  email          String?      @unique
  intent         String?
  status         String
  leadScore      Int?
  tier           String?
  lastMessage    String?
  nextFollowUpAt DateTime?
  metadata       Json?
  termsAccepted  Boolean      @default(false)
  miniAuditData  Json?
  paymentRef     String?
  demoApproved   Boolean      @default(false)
  demoScheduled  Boolean      @default(false)
  updatedAt      DateTime     @updatedAt
  createdAt      DateTime     @default(now())
  demo           Demo?
  emailEvents    EmailEvent[]
  payments       Payment[]
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      String?  @default("user")
  createdAt DateTime @default(now())
}

model TokenizedAsset {
  id              String   @id @default(cuid())
  assetType       String   // LAND, WATCH, CREDIT
  name            String
  location        String?  // Epe, Ikoyi, Banana Island, null for WATCH/CREDIT
  totalShares     Int
  availableShares Int
  pricePerShare   Decimal  @db.Decimal(19, 4) // in NGN (not kobo — Decimal for display)
  currency        String   @default("NGN")
  metadata        Json?    // Additional asset metadata (GPS coordinates, appraisal value, title deeds)
  status          String   @default("ACTIVE") // ACTIVE, FULLY_SUBSCRIBED, SETTLED, CANCELLED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Each share purchase creates a LedgerTransaction via the ledger system
  tokenHolders    TokenHolder[]

  @@map("tokenized_assets")
}

model TokenHolder {
  id              String         @id @default(cuid())
  tokenizedAssetId String
  tokenizedAsset  TokenizedAsset @relation(fields: [tokenizedAssetId], references: [id])
  leadId          String?        // Link to Lead who purchased
  shares          Int
  purchasePrice   Decimal        @db.Decimal(19, 4) // Price per share at purchase time
  totalPaid       Decimal        @db.Decimal(19, 4) // shares * purchasePrice
  transactionId   String?        // Link to LedgerTransaction
  purchasedAt     DateTime       @default(now())

  @@map("token_holders")
}

model Payment {
  id        String   @id @default(cuid())
  amount    Int
  status    String   @default("pending")
  reference String   @unique
  leadId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lead      Lead     @relation(fields: [leadId], references: [id])
}

model Demo {
  id        String   @id @default(cuid())
  slug      String   @unique
  leadId    String   @unique
  config    Json?
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lead      Lead     @relation(fields: [leadId], references: [id])
}

model SystemEvent {
  id        String   @id @default(cuid())
  type      String
  message   String
  digest    String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model SniperTarget {
  id             String    @id @default(cuid())
  source         String
  domain         String
  companyName    String
  firstName      String?
  email          String?
  linkedinUrl    String?
  signal         String?
  status         String    @default("new")
  generatedDraft String?
  draftEmail     String?
  sentAt         DateTime?
  lastAttemptAt  DateTime?
  attemptCount   Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([domain])
  @@index([status])
}

model EmailEvent {
  id        String   @id @default(cuid())
  leadId    String
  type      String
  metadata  Json?
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id])
}

model KnowledgeEmbedding {
  id        String                @id @default(cuid())
  source    String
  url       String?
  embedding Unsupported("vector")
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  chunkId   Int                   @unique
  text      String
  type      String
  metadata  Json?
}

model Embedding {
  id        String   @id @default(cuid())
  content   String
  embedding Float[]
  source    String
  type      String
  createdAt DateTime @default(now())
}

// ──────────────────────────────────────────────────
// HARDENED FINANCIAL CORE — Double-Entry Ledger
// All account balances are derived from Entry rows.
// Never store precomputed balances.
// ──────────────────────────────────────────────────

/// Chart of Accounts — types: WALLET (asset), CLEARING (liability),
/// INCOME (revenue), EXPENSE (cost), EQUITY (capital).
model Account {
  id        String   @id @default(cuid())
  userId    String
  type      String   // WALLET | CLEARING | INCOME | EXPENSE | EQUITY
  currency  String   @default("NGN")
  entries   Entry[]
  createdAt DateTime @default(now())
}

/// A single double-entry transaction. Every transaction
/// must have balanced entries (sum debits = sum credits).
/// State machine: PENDING → POSTED, PENDING → REVERSED, POSTED → REVERSED.
model LedgerTransaction {
  id             String   @id @default(cuid())
  userId         String
  reference      String   @unique
  description    String?  // Human-readable reason for the transaction
  state          String   @default("PENDING") // PENDING | POSTED | REVERSED
  idempotencyKey String   @unique
  entries        Entry[]
  idempotency    LedgerIdempotency? // Optional soft-index for lookups
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  postedAt       DateTime?
}

/// Individual entry leg. Each entry carries either a debit
/// amount (positive) or a credit amount (positive). For any
/// transaction, Σ(debits) must equal Σ(credits).
model Entry {
  id            String            @id @default(cuid())
  transactionId String
  accountId     String
  debit         BigInt            @default(0) // Always ≥ 0. Amount in kobo/subunits.
  credit        BigInt            @default(0) // Always ≥ 0. Amount in kobo/subunits.
  currency      String            @default("NGN")
  description   String?           // Optional line-item memo
  transaction   LedgerTransaction @relation(fields: [transactionId], references: [id])
  account       Account           @relation(fields: [accountId], references: [id])
  createdAt     DateTime          @default(now())
}

/// Optional dedicated table for idempotency lookups.
/// Avoids scanning LedgerTransaction for retried operations.
model LedgerIdempotency {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  transactionId  String   @unique
  transaction    LedgerTransaction @relation(fields: [transactionId], references: [id])
  createdAt      DateTime @default(now())
}
