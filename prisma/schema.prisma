generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id             String    @id @default(cuid())
  phoneNumber    String
  intent         String?
  status         String
  leadScore      Int?
  lastMessage    String?
  nextFollowUpAt DateTime?
  metadata       Json?
  termsAccepted  Boolean   @default(false)
  miniAuditData  Json?
  paymentRef     String?
  demoApproved   Boolean   @default(false)
  updatedAt      DateTime  @updatedAt
  createdAt      DateTime  @default(now())
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String?
  createdAt DateTime @default(now())
}
