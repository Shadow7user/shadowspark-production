# ShadowSpark V1 Environment Configuration

# Authentication (NextAuth v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=https://your-production-domain.web.app

# Database (PostgreSQL)
# Must be a connection string to your managed DB (Neon, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host:5432/shadowspark

# AI & Intelligence
GEMINI_API_KEY=AIza...

# Paystack API Keys
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_WEBHOOK_SECRET=...

# Internal API Secrets
LEAD_SYNC_SECRET=...
