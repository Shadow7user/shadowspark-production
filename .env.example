# ─────────────────────────────────────────────────────────────────────────────
# ShadowSpark Platform — Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Neon (or any PostgreSQL) connection string.
# Get it from: https://console.neon.tech → your project → Connection string
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# ── Auth (NextAuth v5 / Auth.js) ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-32-byte-random-secret"

# Public base URL — used for absolute redirects and Twilio signature verification
NEXT_PUBLIC_BASE_URL="https://shadowspark-tech.org"
# Keep NEXTAUTH_URL in sync with NEXT_PUBLIC_BASE_URL for NextAuth compatibility
NEXTAUTH_URL="https://shadowspark-tech.org"

# ── Twilio (WhatsApp via Twilio Sandbox / Business API) ──────────────────────
# Account SID: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Auth Token: https://console.twilio.com → Account Info
TWILIO_AUTH_TOKEN="your-twilio-auth-token"

# Your Twilio WhatsApp-enabled number (E.164 format, no "whatsapp:" prefix)
# Sandbox: +14155238886
# Production: your approved Twilio WhatsApp number
TWILIO_WHATSAPP_NUMBER="+14155238886"

# ── Meta WhatsApp Business API ────────────────────────────────────────────────
# App Secret: https://developers.facebook.com → App → Settings → Basic
# Used to verify X-Hub-Signature-256 on inbound webhooks.
WHATSAPP_APP_SECRET="your-meta-app-secret"

# Verify token you set in Meta Developer Console → Webhooks → Edit → Verify Token
WHATSAPP_VERIFY_TOKEN="your-random-verify-token"

# System User Access Token (or permanent Page Access Token) used to send outbound
# messages via the Meta Graph API. Generate in:
# Meta Business Suite → Business Settings → System Users → Generate Token
# Required scopes: whatsapp_business_messaging, whatsapp_business_management
WHATSAPP_ACCESS_TOKEN="EAAxxxxxxxxxxxxxx"

# Phone Number IDs from Meta Developer Console → WhatsApp → Phone Numbers
# Each number registered in your Meta Business account has a unique numeric ID.
# Route sales enquiries to the sales number; all other messages to support.
WA_PHONE_NUMBER_ID_SALES="123456789012345"     # replace with your actual sales phone number ID
WA_PHONE_NUMBER_ID_SUPPORT="234567890123456"   # replace with your actual support phone number ID

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Powers the AI response in the WhatsApp webhook.
# If unset, the webhook returns a static fallback message.
OPENAI_API_KEY="sk-..."

# ── Redis (optional — enables rate limiting and job queueing) ─────────────────
# Without this, the app falls back to in-memory rate limiting.
# Upstash: https://console.upstash.com
# Local:   redis://localhost:6379
REDIS_URL="redis://localhost:6379"

# ── Firebase Analytics (optional) ─────────────────────────────────────────────
# Get from: https://console.firebase.google.com → Project Settings → Your Apps
NEXT_PUBLIC_FIREBASE_API_KEY="AIza..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="000000000000"
NEXT_PUBLIC_FIREBASE_APP_ID="1:000000000000:web:xxxxxx"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"

# ── Google Analytics 4 (optional) ────────────────────────────────────────────
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# ── Observability ─────────────────────────────────────────────────────────────
# Protects GET /api/metrics (Prometheus scrape endpoint).
# Leave empty to disable the metrics endpoint.
METRICS_TOKEN="your-random-metrics-token"

# Structured log level: debug | info | warn | error  (default: info)
LOG_LEVEL="info"

# Service name tag in structured logs  (default: shadowspark-platform)
SERVICE_NAME="shadowspark-platform"
