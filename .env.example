# ShadowSpark V1 Environment Configuration

# Authentication (NextAuth v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=https://your-production-domain.web.app

# Database (PostgreSQL)
# Must be a connection string to your managed DB (Neon, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host:5432/shadowspark

# AI & Intelligence
GEMINI_API_KEY=AIza...

# Paystack API Keys
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_WEBHOOK_SECRET=...

# Internal API Secrets
LEAD_SYNC_SECRET=...

# Cron (protect /api/cron/* routes)
CRON_SECRET=...

# Redis (BullMQ queues)
REDIS_URL=redis://localhost:6379

# Firecrawl (RAG sync crawler)
FIRECRAWL_API_KEY=fc_...

# RAG sync (optional overrides)
RAG_CRAWL_ROOT_URL=https://shadowspark-tech.org/blog
RAG_CRAWL_LIMIT=25
RAG_CHUNK_MAX_CHARS=1800
